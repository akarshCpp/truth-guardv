{
  "manifest_version": 3,
  "name": "Truth Guard",
  "version": "1.0",
  "description": "AI Hallucination detector and corrector.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["styles.css"],
      "js": ["content_script.js"]
    }
  ]
}
